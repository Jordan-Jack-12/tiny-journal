generator client {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

generator json {
  provider        = "prisma-json-types-generator"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model journal_block {
  created_at   DateTime
  updated_at   DateTime
  type         String
  jsonObj      Json
  journalId    String       @db.Uuid
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  journal_page journal_page @relation(fields: [journalId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model journal_page {
  created_at    DateTime
  updated_at    DateTime?
  title         String
  description   String?
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String          @db.Uuid
  journal_block journal_block[]
  user_profile  user_profile    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model option {
  text        String
  score       Int
  jump_to     Int      @default(-1)
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question_id String   @db.Uuid
  question    question @relation(fields: [question_id], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model productive_hour {
  date         DateTime
  updateAt     DateTime
  hours        String
  day          Days
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String       @db.Uuid
  user_profile user_profile @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model question {
  text    String
  order   Int
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  test_id String   @db.Uuid
  option  option[]
  test    test     @relation(fields: [test_id], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model result {
  text        String
  score_begin Int
  score_end   Int
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  testId      String @db.Uuid
  test        test   @relation(fields: [testId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model test {
  title        String
  description  String
  slug         String
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question     question[]
  result       result[]
  test_session test_session[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model test_session {
  score   Int
  total   Int
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  test_id String @db.Uuid
  test    test   @relation(fields: [test_id], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_profile {
  first_name      String
  last_name       String
  profile_color   String
  email           String
  created_at      DateTime
  updated_at      DateTime?
  id              String            @id @db.Uuid
  journal_page    journal_page[]
  productive_hour productive_hour[]
}

enum Days {
  SUN
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

enum JournalTypeEnum {
  MOOD
  NOTE
  TODO
  PROMPT
}
