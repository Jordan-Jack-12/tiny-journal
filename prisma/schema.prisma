generator client {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

generator json {
  provider        = "prisma-json-types-generator"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model JournalBlock {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at  DateTime
  updated_at  DateTime
  type        String
  jsonObj     Json
  journalId   String      @db.Uuid
  JournalPage JournalPage @relation(fields: [journalId], references: [id], onDelete: Cascade)

  @@map("journal_block")
}

model JournalPage {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at   DateTime
  updated_at   DateTime?
  title        String
  description  String?
  user_id      String         @db.Uuid
  JournalBlock JournalBlock[]
  UserProfile  UserProfile    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("journal_page")
}

model Option {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  text        String
  score       Int
  jump_to     Int      @default(-1)
  question_id String   @db.Uuid
  Question    Question @relation(fields: [question_id], references: [id])

  @@map("option")
}

model ProductiveHour {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String      @db.Uuid
  date        DateTime
  updateAt    DateTime
  hours       String
  day         Days
  UserProfile UserProfile @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("productive_hour")
}

model Question {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  text    String
  order   Int
  test_id String   @db.Uuid
  Option  Option[]
  Test    Test     @relation(fields: [test_id], references: [id])

  @@map("question")
}

model Result {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  text        String
  score_begin Int
  score_end   Int
  testId      String @db.Uuid
  Test        Test   @relation(fields: [testId], references: [id])

  @@map("result")
}

model Test {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String
  slug        String
  Question    Question[]
  Result      Result[]
  TestSession TestSession[]

  @@map("test")
}

model TestSession {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  score   Int
  total   Int
  test_id String @db.Uuid
  Test    Test   @relation(fields: [test_id], references: [id])

  @@map("test_session")
}

model UserProfile {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name     String
  last_name      String
  profile_color  String
  email          String
  userId         String           @db.Uuid
  created_at     DateTime
  updated_at     DateTime?
  JournalPage    JournalPage[]
  ProductiveHour ProductiveHour[]

  @@map("user_profile")
}

enum Days {
  SUN
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

enum JournalTypeEnum {
  MOOD
  NOTE
  TODO
  PROMPT
}
